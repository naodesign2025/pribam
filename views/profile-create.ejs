<%- include('partials/header', { title: 'プロフィール作成' }) %>

<div class="site-header">
  <a href="/" class="logo-link"><h1 class="logo-text">プリバム</h1></a>
  <a href="/auth/logout" class="btn-logout">ログアウト</a>
</div>

<div class="profile-form-container">
  <div class="prof-book">
    <div class="prof-book-title">
      <span class="rainbow-text">MY PROFILE</span>
      <br>
      <span class="subtitle-text">- プロフィール帳 -</span>
    </div>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/profile/create" method="POST" enctype="multipart/form-data" id="profileForm">

      <!-- アイコン写真 -->
      <div class="prof-section section-pink">
        <div class="section-header">
          <span class="section-icon">★</span>
          アイコン写真
          <span class="section-icon">★</span>
        </div>
        <div class="icon-upload-area">
          <div class="icon-preview-wrapper" onclick="document.getElementById('iconInput').click()">
            <img id="iconPreview" src="/img/default-icon.png" alt="アイコン" class="icon-preview" onerror="this.src='data:image/svg+xml;base64,'">
            <div class="icon-upload-overlay">
              <span>タップして変更</span>
            </div>
          </div>
          <input type="file" id="iconInput" name="icon" accept="image/*" class="hidden-input">
          <p class="upload-hint">JPG/PNG/GIF/WebP・5MBまで</p>
        </div>
      </div>

      <!-- 基本情報 -->
      <div class="prof-section section-cyan">
        <div class="section-header">
          <span class="section-icon">♡</span>
          基本情報
          <span class="section-icon">♡</span>
        </div>
        <div class="form-group">
          <label>ニックネーム <span class="required">必須</span></label>
          <input type="text" name="nickname" required placeholder="あなたのニックネーム" maxlength="30">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>誕生日</label>
            <input type="date" name="birthday">
          </div>
          <div class="form-group">
            <label>血液型</label>
            <select name="blood_type">
              <option value="">選択してね</option>
              <option value="A">A型</option>
              <option value="B">B型</option>
              <option value="O">O型</option>
              <option value="AB">AB型</option>
              <option value="不明">わからない</option>
            </select>
          </div>
        </div>
      </div>

      <!-- 好きなもの -->
      <div class="prof-section section-yellow">
        <div class="section-header">
          <span class="section-icon">☆</span>
          好きなもの
          <span class="section-icon">☆</span>
        </div>
        <div class="form-group">
          <label>好きな食べ物</label>
          <input type="text" name="favorite_food" placeholder="例：ラーメン、チョコレート..." maxlength="100">
        </div>
        <div class="form-group">
          <label>好きなタイプ</label>
          <input type="text" name="favorite_type" placeholder="例：優しくて面白い人！" maxlength="100">
        </div>
      </div>

      <!-- たからもの -->
      <div class="prof-section section-green">
        <div class="section-header">
          <span class="section-icon">★</span>
          たからもの・ほしいもの
          <span class="section-icon">★</span>
        </div>
        <div class="form-group">
          <label>たからもの</label>
          <input type="text" name="treasure" placeholder="例：おじいちゃんにもらった時計" maxlength="150">
        </div>
        <div class="form-group">
          <label>今ほしいもの</label>
          <input type="text" name="want_now" placeholder="例：新しいスニーカー！" maxlength="150">
        </div>
      </div>

      <!-- マイBEST3 -->
      <div class="prof-section section-purple">
        <div class="section-header">
          <span class="section-icon">♡</span>
          マイ BEST 3
          <span class="section-icon">♡</span>
        </div>
        <div class="best3-wrapper">
          <div class="best3-item">
            <span class="best3-rank rank-1">1st</span>
            <input type="text" name="best3_1" placeholder="第1位！" maxlength="50">
          </div>
          <div class="best3-item">
            <span class="best3-rank rank-2">2nd</span>
            <input type="text" name="best3_2" placeholder="第2位！" maxlength="50">
          </div>
          <div class="best3-item">
            <span class="best3-rank rank-3">3rd</span>
            <input type="text" name="best3_3" placeholder="第3位！" maxlength="50">
          </div>
        </div>
      </div>

      <!-- もしもコーナー -->
      <div class="prof-section section-orange">
        <div class="section-header">
          <span class="section-icon">☆</span>
          もしもコーナー
          <span class="section-icon">☆</span>
        </div>
        <div class="form-group">
          <label>もし○○だったら…？</label>
          <input type="text" name="moshimo_q" placeholder="例：もし魔法が使えたら" maxlength="80">
        </div>
        <div class="form-group">
          <label>答え</label>
          <input type="text" name="moshimo_a" placeholder="例：時間を止めたい！" maxlength="150">
        </div>
      </div>

      <!-- FREE SPACE -->
      <div class="prof-section section-pink">
        <div class="section-header">
          <span class="section-icon">★</span>
          FREE SPACE
          <span class="section-icon">★</span>
        </div>
        <div class="form-group">
          <textarea name="free_space" rows="4" placeholder="なんでも自由に書いてね！趣味・近況・ひとことなど..." maxlength="500"></textarea>
          <span class="char-count" data-target="free_space" data-max="500">0 / 500</span>
        </div>
      </div>

      <!-- LOVE LOVEコーナー -->
      <div class="prof-section section-red">
        <div class="section-header">
          <span class="section-icon">♡</span>
          LOVE LOVE コーナー
          <span class="section-icon">♡</span>
        </div>
        <div class="form-group">
          <label>ステータス</label>
          <div class="love-options">
            <label class="love-radio">
              <input type="radio" name="love_status" value="彼氏いる">
              <span class="love-badge badge-blue">彼氏いる</span>
            </label>
            <label class="love-radio">
              <input type="radio" name="love_status" value="彼女いる">
              <span class="love-badge badge-pink">彼女いる</span>
            </label>
            <label class="love-radio">
              <input type="radio" name="love_status" value="いない">
              <span class="love-badge badge-gray">いない</span>
            </label>
            <label class="love-radio">
              <input type="radio" name="love_status" value="ひみつ">
              <span class="love-badge badge-purple">ひみつ</span>
            </label>
          </div>
        </div>
        <div class="form-group">
          <label>ひとこと</label>
          <input type="text" name="love_comment" placeholder="例：もうすぐ記念日！" maxlength="100">
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-large">
          プロフを保存する！
        </button>
      </div>

    </form>
  </div>
</div>

<%- include('partials/footer') %>
