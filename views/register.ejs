<%- include('partials/header', { title: '新規登録' }) %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <h1 class="logo-text">プリバム</h1>
      <p class="logo-sub">★ まずはアカウントを作ろう！ ★</p>
    </div>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="username">ユーザー名</label>
        <input type="text" id="username" name="username" required placeholder="あなたの名前" maxlength="30">
      </div>
      <div class="form-group">
        <label for="email">メールアドレス</label>
        <input type="email" id="email" name="email" required placeholder="example@mail.com">
      </div>
      <div class="form-group">
        <label for="password">パスワード（6文字以上）</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" minlength="6">
      </div>
      <div class="form-group">
        <label for="password_confirm">パスワード確認</label>
        <input type="password" id="password_confirm" name="password_confirm" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        登録してプロフを作ろう！
      </button>
    </form>

    <div class="auth-switch">
      すでにアカウントがある人は
      <a href="/auth/login" class="link-fancy">ログインはこちら！</a>
    </div>
  </div>

  <div class="deco-stars" aria-hidden="true">
    <span class="star s1">★</span>
    <span class="star s2">☆</span>
    <span class="star s3">★</span>
    <span class="star s4">☆</span>
  </div>
</div>

<%- include('partials/footer') %>
