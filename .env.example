# ============================================
# プリバム 環境変数設定
# このファイルを .env にコピーして値を入力してください
# ============================================

# Supabase の接続文字列
# Supabase Dashboard > Project Settings > Database > Connection string (URI) からコピー
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# 本番環境では true に設定
DATABASE_SSL=true

# JWT署名シークレット（長くランダムな文字列を設定）
# 例: openssl rand -hex 32 で生成
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase Storage用（画像アップロード）
# Supabase Dashboard > Project Settings > API から取得
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...（service_role の secret key）

# サーバーポート（省略時は3000）
PORT=3000

# 環境設定
NODE_ENV=development
